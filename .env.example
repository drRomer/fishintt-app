# =============================================================================
# Fishin't — Variables de entorno
# =============================================================================
# Copia este archivo a .env.local para desarrollo local
# Estas variables se configuran en Vercel para producción

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# -----------------------------------------------------------------------------
# Las encuentras en: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# Solo para operaciones server-side (RLS bypass). NO exponer en cliente.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# APIs externas (opcionales para MVP, se pueden activar después)
# -----------------------------------------------------------------------------
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Google Safe Browsing
GOOGLE_SAFE_BROWSING_KEY=

# -----------------------------------------------------------------------------
# IA para anatomía de enlaces (OPCIONAL, gratis)
# -----------------------------------------------------------------------------
# Google Gemini — tier gratuito. Obtén tu key en https://aistudio.google.com/apikey
# Si se deja vacío, el análisis usa la heurística determinista (sin IA).
GEMINI_API_KEY=
